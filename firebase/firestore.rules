rules_version = '2';

// LA COCINA DE JAVI — Reglas de Firestore
// Público: crear pedidos y votos (validados).
// Usuarios logueados: su propio perfil.
// Admin (allowlist de mails): gestiona todo.

service cloud.firestore {
  match /databases/{database}/documents {

    function logueado() {
      return request.auth != null;
    }

    // Admin por mail. Debe coincidir con CONFIG.adminEmails (js/config.js).
    function esAdmin() {
      return request.auth != null
        && request.auth.token.email in ['tukyquilme@gmail.com'];
    }

    function textoCorto(campo, max) {
      return request.resource.data[campo] is string
        && request.resource.data[campo].size() > 0
        && request.resource.data[campo].size() <= max;
    }

    // Perfiles: cada quien lee/escribe el suyo; el admin puede leer todos.
    match /users/{uid} {
      allow read: if request.auth != null && (request.auth.uid == uid || esAdmin());
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Pedidos: cualquiera crea, solo el admin lee/gestiona.
    match /pedidos/{id} {
      allow create: if textoCorto('nombre', 60)
        && textoCorto('telefono', 30)
        && request.resource.data.items is list
        && request.resource.data.items.size() > 0
        && request.resource.data.items.size() <= 20
        && request.resource.data.total is number
        && request.resource.data.total >= 0
        && request.resource.data.estado == 'nuevo';
      allow read, update, delete: if esAdmin();
    }

    // Votos: cualquiera crea y lee (para contar). Sin teléfono en el voto.
    match /votos/{id} {
      allow create: if textoCorto('nombre', 60)
        && textoCorto('fecha', 12)
        && textoCorto('opcion', 80)
        && request.resource.data.porciones is number
        && request.resource.data.porciones >= 1
        && request.resource.data.porciones <= 40
        && !('telefono' in request.resource.data);
      allow read: if true;
      allow update, delete: if esAdmin();
    }

    // Contacto de votantes: se crea junto al voto, solo el admin lo lee.
    match /votos_contacto/{id} {
      allow create: if textoCorto('telefono', 30);
      allow read, update, delete: if esAdmin();
    }

    // Config pública (parámetros): lee cualquiera, escribe el admin.
    match /config/{id} {
      allow read: if true;
      allow write: if esAdmin();
    }

    // Sugerencias de platos: cualquiera crea (validado), solo el admin lee.
    match /sugerencias/{id} {
      allow create: if textoCorto('nombre', 60) && textoCorto('plato', 80);
      allow read, update, delete: if esAdmin();
    }

    // Gastos y platos/rondas (fase 2): solo el admin.
    match /gastos/{id} {
      allow read, write: if esAdmin();
    }
    match /platos/{id} {
      allow read: if true;                 // el público ve los platos a votar
      allow write: if esAdmin();
    }
  }
}
